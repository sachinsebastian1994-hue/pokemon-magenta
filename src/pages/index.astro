---
const ogImage = new URL('/og.png', Astro.site).href;
const title = "POKéMON MAGENTA";
const description = "A fan-made Pokémon game with Gen-1 Pokémon, full battle system, and overworld exploration — playable in the browser.";
---

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<meta name="theme-color" content="#b8126e">
<title>{title}</title>
<meta name="description" content={description}>

<!-- Open Graph (Facebook, WhatsApp, iMessage, Slack, Discord) -->
<meta property="og:type" content="website">
<meta property="og:url" content={Astro.url.href}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1280">
<meta property="og:image:height" content="640">

<!-- Twitter / X card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImage}>

<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='50' r='44' fill='%23e8285a'/><rect x='6' y='47' width='88' height='6' fill='%23222'/><circle cx='50' cy='50' r='14' fill='%23fff' stroke='%23222' stroke-width='6'/></svg>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div id="stage">
  <div id="shell">
    <div id="shell-top"><span class="shell-led"></span><span class="shell-brand">GAME&nbsp;PERSON&trade;</span><span class="shell-model">MAGENTA&nbsp;SP</span></div>
    <div id="screen-frame">
      <div id="screen">
        <canvas id="game" width="240" height="160"></canvas>
        <div id="ui"></div>
        <div id="battle" class="hidden"></div>
        <div id="title" class="hidden"></div>
        <div id="fade"></div>
      </div>
    </div>
    <div id="shell-bottom">POKéMON&nbsp;MAGENTA&nbsp;VERSION</div>
  </div>

  <div id="controls">
    <div id="dpad">
      <button class="pad-btn" data-k="up"    id="pad-up"><span>▲</span></button>
      <button class="pad-btn" data-k="left"  id="pad-left"><span>◀</span></button>
      <div id="pad-center"></div>
      <button class="pad-btn" data-k="right" id="pad-right"><span>▶</span></button>
      <button class="pad-btn" data-k="down"  id="pad-down"><span>▼</span></button>
    </div>
    <div id="action-btns">
      <button id="btn-start" class="sys-btn" data-k="start">START</button>
      <div id="ab">
        <button class="ab-btn" data-k="b" id="btn-b">B</button>
        <button class="ab-btn" data-k="a" id="btn-a">A</button>
      </div>
    </div>
  </div>
</div>

<script is:inline src="/js/data.js"></script>
<script is:inline src="/js/tiles.js"></script>
<script is:inline src="/js/maps.js"></script>
<script is:inline src="/js/ui.js"></script>
<script is:inline src="/js/battle.js"></script>
<script is:inline src="/js/game.js"></script>
<script is:inline src="/js/main.js"></script>
</body>
</html>
